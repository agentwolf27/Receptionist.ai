# Database (SQLite for local dev). For Supabase/Postgres set e.g.:
#   DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"
DATABASE_URL="file:./dev.db"

# Required: random string used to sign session cookies
SESSION_SECRET="generate-a-long-random-string-here"

# Display name shown in the UI
NEXT_PUBLIC_APP_NAME="Receptionist.ai"

# ----- Optional: real provider credentials (mock providers are used until these are set) -----
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""
# VAPI_API_KEY=""
# SUPABASE_URL=""
# SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""
# GOOGLE_CALENDAR_CLIENT_ID=""
# GOOGLE_CALENDAR_CLIENT_SECRET=""
