# =============================================================================
# Supabase Postgres (default) — copy to `.env` and fill passwords from Dashboard → Connect
# Prisma CLI reads `.env` (not only `.env.local`). Next.js merges `.env` + `.env.local`.
# =============================================================================
#
# 1) Dashboard → Connect → URI
#
# DATABASE_URL — Transaction pooler (port 6543, IPv4-friendly). Example shape:
#   postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres
# Prisma: append query params (use & if the URI already contains ?):
#   ?pgbouncer=true&sslmode=require
#
# DIRECT_URL — Session pooler (port 5432 on the SAME pooler host) for migrations on IPv4.
#   postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres?sslmode=require
# Avoid relying on db.<ref>.supabase.co:5432 alone — it is often IPv6-only from home networks.
#
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/receptionist?schema=public"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/receptionist?schema=public"

# ----- Optional: local Docker Postgres instead of Supabase -----
# docker run --name receptionist-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=receptionist -p 5432:5432 -d postgres:16
# Then use the two localhost URLs above.

# Required: random string used to sign session cookies
SESSION_SECRET="generate-a-long-random-string-here"

# Display name shown in the UI
NEXT_PUBLIC_APP_NAME="Receptionist.ai"

# ----- Optional: real provider credentials (mock providers are used until these are set) -----
# Groq (OpenAI-compatible) — AI receptionist simulator + /api/simulate use this when set:
#   https://console.groq.com/keys
# GROQ_API_KEY=""   # paste key from https://console.groq.com/keys — use .env.local only, never commit
# GROQ_MODEL="llama-3.3-70b-versatile"
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""
# VAPI_API_KEY=""
# Optional shared secret for POST /api/voice/webhook (voice provider callbacks)
# VOICE_WEBHOOK_SECRET=""
# Supabase (optional until you use Supabase Auth or client helpers)
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# Use either the legacy anon JWT or the newer publishable key (dashboard-dependent):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""  # server-only; never NEXT_PUBLIC_
# GOOGLE_CALENDAR_CLIENT_ID=""
# GOOGLE_CALENDAR_CLIENT_SECRET=""
